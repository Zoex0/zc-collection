rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【临时调试】先允许所有已登录用户写入，确认 UID 后再锁定
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'LKD6nn7yCaQtNoTVGNf02IYKNBE2';
    }

    // photos 集合：所有人可读，已登录用户可写（调试中）
    match /photos/{photoId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // tags 集合：所有人可读，已登录用户可写（调试中）
    match /tags/{tagId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // settings 集合：已登录用户可读写（调试中）
    match /settings/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
